# Local development environment variables for SecureCollab

# Ports
GATEWAY_PORT=8080
AUTH_PORT=8081
KEYDIST_PORT=8082
MESSAGING_PORT=8083
ANALYTICS_PORT=8084
POSTGRES_PORT=5432
REDIS_PORT=6379
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
REDPANDA_PORT=9092
CONNECT_PORT=8085
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# Security
JWT_SECRET=securecollab-dev-secret-key

# Database and cache
DATABASE_URL=postgres://securecollab:securecollab@localhost:5432/securecollab?sslmode=disable
AUTH_TEST_DATABASE_URL=postgres://securecollab:securecollab@localhost:5432/securecollab?sslmode=disable
KEYDIST_TEST_DATABASE_URL=postgres://securecollab:securecollab@localhost:5432/securecollab?sslmode=disable
MESSAGING_TEST_DATABASE_URL=postgres://securecollab:securecollab@localhost:5432/securecollab?sslmode=disable
ANALYTICS_TEST_DATABASE_URL=postgres://securecollab:securecollab@localhost:5432/securecollab?sslmode=disable
REDIS_ADDR=localhost:6379
CDC_CONNECT_URL=http://localhost:8085

# Gateway smoke/load-test endpoint base
GATEWAY_BASE_URL=http://localhost:8080

# Optional load-test token (leave empty if testing unauthorized path)
GATEWAY_JWT=
